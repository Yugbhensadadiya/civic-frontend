# Production Environment Variables (for reference)
# These should be set in Vercel project settings, not committed to git

# Backend API URL for production
NEXT_PUBLIC_API_URL=https://civic-backend-2.onrender.com

# Frontend URL
NEXT_PUBLIC_APP_URL=https://civic-frontend-three.vercel.app

# Security
NEXT_PUBLIC_APP_ENV=production

# Optional: Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true
